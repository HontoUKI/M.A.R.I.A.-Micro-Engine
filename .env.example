# Copy to .env and adjust. Real env vars override .env; .env is never committed.

# Which backend generates responses: "ollama" (local) or "openai" (cloud).
LLM_BACKEND=ollama

# Ollama backend (LLM_BACKEND=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
CHAT_MODEL=gemma3:12b
EMBED_MODEL=nomic-embed-text

# OpenAI backend (LLM_BACKEND=openai). Paste your API key here; it stays on the
# server and is never sent to clients.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# Sampling for the voicing model
TEMPERATURE=0.8
# Context window in tokens. Leave unset to use the model's own default.
# NUM_CTX=8192

# Engine runtime state directory (never committed)
DATA_DIR=data

# Per-session relationship state + transcripts (never committed). A long
# correspondence resumes from here across restarts.
SESSIONS_DIR=.local/sessions

# Non-roleplay mode: the character stays in voice but stops narrating its own
# actions (*smiles*, stage directions) and answers like a plain pet-assistant.
NON_RP=false

# Non-romance mode: the relationship stays strictly platonic no matter how close
# it grows — warmth and friendship still deepen, but flirtation and romance are
# refused (romantic advances are gently redirected to friendship).
NON_ROMANCE=false

# Reply language (e.g. Russian, Japanese). Empty = the character answers in
# whatever language the user writes in. A per-request `language` field overrides
# this default (the web UI exposes it as a dropdown).
LANGUAGE=

# The user's grammatical gender (male / female), so a character addresses them
# with the right pronouns and agreement in gendered languages (Russian, etc.).
# Empty = unspecified. A per-request `user_gender` field overrides this default.
USER_GENDER=

# Opt-in web lookup (OFF by default). When true, a turn a pack tags as
# `web_lookup` runs a DuckDuckGo search and grounds the reply on the snippets.
# Enables outbound network — leave off unless you want it.
WEB_SEARCH=false
WEB_SEARCH_RESULTS=3

# Logging: DEBUG | INFO | WARNING | ERROR. Token usage is logged at INFO.
LOG_LEVEL=INFO

# Relationship axis ceiling. Higher = slower burn (the same per-turn deltas
# become a smaller fraction of the whole). Try 1000 for a long, slow arc.
AXIS_MAX=100
